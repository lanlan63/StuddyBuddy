extends layout

block content
  h1 Study Sessions
  p.subtitle Browse all available sessions or filter by topic.

  if selectedTag
    p Showing results for: 
      strong= selectedTag
      |  – 
      a(href="/sessions") Clear filter

  .sessions-list
    each session in sessions
      .session-card
        h2= session.topic
        p.location 📍 #{session.location || 'Location TBD'}
        p.time 📅 #{new Date(session.scheduled_time).toLocaleString('en-GB')}
        p.host 👤 #{session.first_name} #{session.last_name}
        p.capacity 👥 #{session.slots_taken} / #{session.max_participants || '∞'}
        a.btn(href="/sessions/" + session.session_id) Session Details
