extends layout

block content
  h1 Study Sessions
  a(href="/tags") Browse by Topic
  .grid
    each session in sessions
      .card
        h2= session.topic
        p= session.location || 'TBD'
        p= new Date(session.scheduled_time).toLocaleString('en-GB')
        p= session.first_name + ' ' + session.last_name
        p= session.joined + '/' + (session.max_participants || '∞')
        a.btn(href="/sessions/" + session.session_id) Details
