extends layout

block content
  h1 All Study Sessions
  .sessions-grid
    each session in sessions
      .session-card
        h2= session.topic
        p 📍 #{session.location || 'TBD'}
        p 📅 #{session.formatted_time}
        p 👤 #{session.first_name} #{session.last_name}
        p 👥 #{session.participants_joined}/#{session.max_participants || '∞'}
        a.btn(href="/sessions/" + session.session_id) View Details
